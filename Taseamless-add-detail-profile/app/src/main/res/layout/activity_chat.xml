<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp"
        android:background="@color/deepBlue"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            app:srcCompat="@drawable/ic_chevron"
            app:tint="@color/cream" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">

            <TextView
                android:id="@+id/txtChatTaskName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Task Name"
                android:textColor="@color/cream"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtChatProjectName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Project Name"
                android:textColor="@color/grey"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ===== PINNED MESSAGES BANNER ===== -->
    <LinearLayout
        android:id="@+id/llPinnedBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8F5E9"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            app:srcCompat="@android:drawable/ic_menu_today"
            app:tint="@color/deepGreen"
            android:layout_marginEnd="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tin nhắn đã ghim"
                android:textColor="@color/deepGreen"
                android:textStyle="bold"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/txtPinnedBannerContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/deepBlue"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnViewAllPinned"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:srcCompat="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/deepGreen" />
    </LinearLayout>

    <!-- ===== MESSAGES RECYCLER ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- ===== RECORDING INDICATOR ===== -->
    <LinearLayout
        android:id="@+id/llRecording"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:background="@color/deepBlue"
        android:visibility="gone">

        <View
            android:id="@+id/vRecordingDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_circle_active"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang ghi âm..."
            android:textColor="@color/cream"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtRecordTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  0:00"
            android:textColor="@color/green"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ===== UPLOAD PROGRESS ===== -->
    <LinearLayout
        android:id="@+id/llUploadProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="@color/deepBlue"
        android:visibility="gone">

        <!-- Image preview when uploading -->
        <ImageView
            android:id="@+id/imgUploadPreview"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="8dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ProgressBar
                android:id="@+id/uploadProgressBar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progressTint="@color/deepGreen" />

            <TextView
                android:id="@+id/txtUploadPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/cream"
                android:textSize="12sp"
                android:text="0%" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== MENTIONS RECYCLER ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMentions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAFA"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintHeight_max="150dp" />

    <!-- ===== REPLY PREVIEW ===== -->
    <LinearLayout
        android:id="@+id/llReplyPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8F5E9"
        android:padding="8dp"
        android:visibility="gone">
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/deepGreen" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">
            <TextView
                android:id="@+id/txtReplyPreviewSender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/deepGreen"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/txtReplyPreviewContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/deepBlue"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>
        <ImageView
            android:id="@+id/btnCloseReply"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="8dp"
            app:srcCompat="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/grey" />
    </LinearLayout>

    <!-- ===== INPUT BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp"
        android:background="@color/deepBlue">

        <!-- Attach button -->
        <ImageView
            android:id="@+id/btnAttach"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_grey"
            android:padding="10dp"
            app:srcCompat="@drawable/ic_attach"
            app:tint="@color/cream"
            android:layout_marginEnd="6dp" />

        <!-- Text input -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Message..."
            android:textColorHint="@color/cream"
            android:textColor="@color/cream"
            android:textSize="14sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_deep_green"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:imeOptions="actionSend" />

        <!-- Mic button (hold to record) -->
        <ImageView
            android:id="@+id/btnMic"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_grey"
            android:padding="10dp"
            app:srcCompat="@drawable/ic_mic"
            app:tint="@color/cream"
            android:layout_marginStart="6dp" />

        <!-- Send button -->
        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_active"
            android:padding="10dp"
            app:srcCompat="@drawable/ic_send"
            app:tint="@color/cream"
            android:layout_marginStart="6dp" />

    </LinearLayout>

</LinearLayout>
