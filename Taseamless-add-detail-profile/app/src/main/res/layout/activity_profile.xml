<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/deepBlue">

    <!-- Header with Back Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBackProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            app:srcCompat="@drawable/ic_chevron"
            app:tint="@color/cream"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/txtProfileHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile Detail"
            android:textColor="@color/cream"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgProfileAvatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile"
                app:shapeAppearanceOverlay="@style/CircleShape"
                app:strokeColor="@color/cream"
                app:strokeWidth="3dp"
                android:layout_marginBottom="16dp"
                android:padding="3dp"/>

            <TextView
                android:id="@+id/txtChangeAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change Avatar"
                android:textColor="@color/green"
                android:textSize="14sp"
                android:layout_marginBottom="30dp"
                android:clickable="true"
                android:focusable="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_deep_green"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="@color/green"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txtProfileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="@color/cream"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="@color/green"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txtProfileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="@color/cream"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Role"
                    android:textColor="@color/green"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txtProfileRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="@color/cream"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/lblManagedBy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Managed By"
                    android:textColor="@color/green"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txtManagedBy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="None"
                    android:textColor="@color/cream"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp" />

                <!-- Project Count Section -->
                <TextView
                    android:id="@+id/lblProjectCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Projects Participated"
                    android:textColor="@color/green"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txtProjectCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/cream"
                    android:textSize="18sp" />

            </LinearLayout>

            <Button
                android:id="@+id/btnMessageUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Message"
                android:backgroundTint="@color/deepBlue"
                android:textColor="@color/cream"
                android:layout_marginTop="20dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Log Out"
                android:backgroundTint="#FF5252"
                android:textColor="@color/cream"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>