<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/deepBlue">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Information"
        android:textColor="@color/green"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etFullName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Full Name"
        android:textColor="@color/cream"
        android:textColorHint="@color/lightGrey"
        android:background="@drawable/bg_deep_green_stroke"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:textColor="@color/cream"
        android:textColorHint="@color/lightGrey"
        android:background="@drawable/bg_deep_green_stroke"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:textColor="@color/cream"
        android:textColorHint="@color/lightGrey"
        android:background="@drawable/bg_deep_green_stroke"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvRoleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Role"
        android:textColor="@color/cream"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spRole"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_deep_green_stroke"
        android:layout_marginBottom="12dp"
        android:paddingHorizontal="12dp"
        android:spinnerMode="dropdown"/>

    <TextView
        android:id="@+id/tvManagerLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Assign Manager (For Employees)"
        android:textColor="@color/cream"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spManager"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_deep_green_stroke"
        android:layout_marginBottom="20dp"
        android:paddingHorizontal="12dp"
        android:spinnerMode="dropdown"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:backgroundTint="@color/deepBlue"
            android:textColor="@color/cream"
            style="@style/Widget.MaterialComponents.Button.TextButton"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:backgroundTint="@color/green"
            android:textColor="@color/deepBlue"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>