<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/logoGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="35dp"
        android:baselineAligned="true"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.432"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tas"
            android:textColor="@color/deepBlue"
            android:textSize="90sp"
            android:textStyle="bold|italic" />

        <TextView
            android:id="@+id/txtTitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/eamless"
            android:textColor="@color/deepBlue"
            android:textSize="50sp"
            android:textStyle="italic" />

    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.27086183" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgView"
        android:layout_width="182dp"
        android:layout_height="187dp"
        android:layout_marginStart="20dp"
        android:elevation="8dp"
        android:padding="7dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toTopOf="@+id/imgView2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideline"
        app:shapeAppearanceOverlay="@style/CircleShape"
        app:srcCompat="@mipmap/ic_people"
        app:strokeColor="@color/deepGreen"
        app:strokeWidth="7dp" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgView2"
        android:layout_width="142dp"
        android:layout_height="144dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="20dp"
        android:elevation="8dp"
        android:padding="3dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toTopOf="@+id/imgView3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideline"
        app:layout_constraintVertical_bias="0.8"
        app:shapeAppearanceOverlay="@style/CircleShape"
        app:srcCompat="@mipmap/ic_todo"
        app:strokeColor="@color/deepGreen"
        app:strokeWidth="5dp" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgView3"
        android:layout_width="121dp"
        android:layout_height="117dp"
        android:layout_marginStart="128dp"
        android:layout_marginTop="184dp"
        android:elevation="8dp"
        android:padding="6dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toTopOf="@+id/edtUsername"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideline"
        app:layout_constraintVertical_bias="0.285"
        app:shapeAppearanceOverlay="@style/CircleShape"
        app:srcCompat="@mipmap/ic_fast"
        app:strokeColor="@color/deepGreen"
        app:strokeWidth="6dp" />

    <EditText
        android:id="@+id/edtUsername"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginHorizontal="32dp"
        android:background="@drawable/bg_deep_green"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColorHint="@color/cream"
        android:textStyle="bold"
        android:textColor="@color/cream"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@+id/edtPassword"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:shapeAppearanceOverlay="@style/CircleShape"
        android:text="boss@gmail.com"/>

    <EditText
        android:id="@+id/edtPassword"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginHorizontal="32dp"
        android:background="@drawable/bg_deep_green"
        android:hint="Password"
        android:inputType="textPassword"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColorHint="@color/white"
        android:textStyle="bold"
        android:textColor="@color/cream"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@+id/btnLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:text="123456"/>


    <Button
        android:id="@+id/btnLogin"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginHorizontal="32dp"
        android:backgroundTint="@color/deepBlue"
        android:text="Log In"
        android:textColor="@color/cream"
        android:textSize="20sp"
        android:textStyle="bold"
        app:cornerRadius="20dp"
        android:layout_marginBottom="35dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>