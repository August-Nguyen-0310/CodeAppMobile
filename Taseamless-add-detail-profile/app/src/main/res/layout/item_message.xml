<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <!-- SENDER AVATAR (Left) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgSender"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_profile"
        app:shapeAppearanceOverlay="@style/CircleShape"
        app:strokeColor="@color/deepBlue"
        app:strokeWidth="1dp"
        android:padding="1dp"/>

    <LinearLayout
        android:id="@+id/llMessageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/imgSender"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/grey"
            android:textSize="11sp"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="2dp"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/llMessageBubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <LinearLayout
                android:id="@+id/llMessageBackground"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_deep_green"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:id="@+id/llReplyContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#33000000"
                    android:padding="6dp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtRepliedSender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/cream"/>

                    <TextView
                        android:id="@+id/txtRepliedContent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/grey"
                        android:maxLines="2"
                        android:ellipsize="end"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtMessageContent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="260dp"
                    android:text="Message content"
                    android:textColor="@color/cream"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/imgMessageContent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="200dp"
                    android:maxHeight="250dp"
                    android:adjustViewBounds="true"
                    android:scaleType="centerInside"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtMessageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="10:00"
                android:textColor="@color/grey"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>